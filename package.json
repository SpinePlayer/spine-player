{
  "name": "spine-web-player",
  "version": "4.2.0",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/spine-player.umd.js",
  "module": "./dist/spine-player.es.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/spine-player.es.js",
      "require": "./dist/spine-player.umd.js",
      "types": "./dist/types/index.d.ts"
    },
    "./vue3": {
      "import": "./dist/vue3/spine-player-vue3.es.js",
      "types": "./dist/types/vue3/index.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "vue3": [
        "./dist/types/vue3/index.d.ts"
      ]
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:umd",
    "build:umd": "vite build --config vite.umd.config.ts",
    "preview": "vite preview",
    "release": "sh release.sh patch"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/plugin-transform-runtime": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "^7.27.1",
    "@babel/runtime": "^7.28.4",
    "@types/node": "^20.19.10",
    "@vitejs/plugin-vue": "^5.2.4",
    "core-js": "^3.45.1",
    "postcss-px-to-viewport": "^1.1.1",
    "sass": "^1.90.0",
    "terser": "^5.43.1",
    "typescript": "^5.9.2",
    "vite": "^5.4.19",
    "vite-plugin-babel": "^1.3.2",
    "vite-plugin-dts": "^4.5.4",
    "vue-tsc": "^1.8.27",
    "vue": "^3.5.18"
  },
  "dependencies": {
    "@esotericsoftware/spine-canvas": "~4.2.89",
    "@esotericsoftware/spine-webgl": "~4.2.89"
  }
}
